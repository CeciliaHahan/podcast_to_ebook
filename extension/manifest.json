{
  "manifest_version": 3,
  "name": "Podcasts to Ebooks",
  "description": "Convert podcast inputs into EPUB/PDF/Markdown from a Side Panel workspace.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "permissions": ["sidePanel", "storage"],
  "host_permissions": [
    "http://localhost:8080/*",
    "http://127.0.0.1:8080/*",
    "https://api.example.com/*"
  ],
  "action": {
    "default_title": "Podcasts to Ebooks",
    "default_popup": "popup/popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  }
}
